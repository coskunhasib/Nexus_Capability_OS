      "related_tools": ["test-runner", "schema-validator"],
      "compatible_packs": ["web-saas-mvp-pack", "agentic-system-pack", "firmware-stm32-hvac-driver-pack"],
      "research_policy": { "requires_current_research": true, "required_sources": ["external skill docs", "agent planning papers", "software testing references", "reliability engineering references"], "research_questions": ["What planning failures occur most often in agentic execution?", "Which edge-case discovery methods are most reliable?", "How should gap-catching be evaluated?" ] },
