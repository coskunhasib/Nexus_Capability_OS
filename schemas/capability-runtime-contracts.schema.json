{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/capability-runtime-contracts.schema.json",
  "title": "Nexus Capability Runtime Contracts",
  "type": "object",
  "description": "Schema index for the first Capability Runtime contract fixture set. TypeScript verifier remains the deterministic enforcement source, and this schema now mirrors stricter enum/nested requirements.",
  "oneOf": [
    { "$ref": "#/$defs/SkillPackage" },
    { "$ref": "#/$defs/ToolGrant" },
    { "$ref": "#/$defs/AgentProfile" },
    { "$ref": "#/$defs/SubAgentDelegation" },
    { "$ref": "#/$defs/MemoryNote" },
    { "$ref": "#/$defs/ActiveContextBundle" },
    { "$ref": "#/$defs/EvaluationObservation" },
    { "$ref": "#/$defs/RuntimeLoopCycle" }
  ],
  "$defs": {
    "NonEmptyString": { "type": "string", "minLength": 1 },
    "StringArray": { "type": "array", "items": { "$ref": "#/$defs/NonEmptyString" } },
    "NonEmptyStringArray": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/NonEmptyString" } },
    "ToolActionClass": { "enum": ["read_only", "write_artifact", "write_workspace", "network_read", "network_write", "runtime_control", "system_sensitive"] },
    "RuntimeSignal": { "enum": ["positive", "negative", "neutral", "unknown"] },
    "RuntimeConfidence": { "enum": ["low", "medium", "high"] },
    "RuntimeStatus": { "enum": ["pass", "partial", "fail"] },
    "MemoryNoteType": { "enum": ["decision", "preference", "lesson", "failure", "pattern", "constraint", "open_question", "artifact_summary"] },
    "MemoryNoteStatus": { "enum": ["active", "stale", "retired"] },
    "EvaluationSubjectType": { "enum": ["skill", "tool", "agent", "sub_agent", "context", "memory_note", "artifact", "gate"] },
    "AuditLevel": { "enum": ["summary", "full"] },
    "SkillMethodStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "instruction", "output_kind"],
      "anyOf": [
        { "required": ["required_tool_refs"] },
        { "required": ["required_gate_refs"] }
      ],
      "properties": {
        "step_id": { "$ref": "#/$defs/NonEmptyString" },
        "instruction": { "$ref": "#/$defs/NonEmptyString" },
        "output_kind": { "$ref": "#/$defs/NonEmptyString" },
        "required_tool_refs": { "$ref": "#/$defs/StringArray" },
        "required_gate_refs": { "$ref": "#/$defs/StringArray" }
      }
    },
    "WorkspaceBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_read_paths", "allowed_write_paths", "blocked_paths", "artifact_output_root"],
      "properties": {
        "allowed_read_paths": { "$ref": "#/$defs/StringArray" },
        "allowed_write_paths": { "$ref": "#/$defs/StringArray" },
        "blocked_paths": { "$ref": "#/$defs/StringArray" },
        "artifact_output_root": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "ExcludedRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "reason"],
      "properties": {
        "ref": { "$ref": "#/$defs/NonEmptyString" },
        "reason": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "RuntimeEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_type", "summary"],
      "properties": {
        "event_type": { "$ref": "#/$defs/NonEmptyString" },
        "summary": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "RuntimeArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref", "summary"],
      "properties": {
        "kind": { "$ref": "#/$defs/NonEmptyString" },
        "ref": { "$ref": "#/$defs/NonEmptyString" },
        "summary": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "SkillPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "skill_id", "name", "purpose", "when_to_use", "when_not_to_use", "required_inputs", "method_steps", "required_tools", "optional_tools", "agent_profile_hints", "sub_agent_hints", "quality_gates", "risk_notes", "expected_outputs", "observation_metrics"],
      "properties": {
        "packet_type": { "const": "nexus.skill_package" },
        "version": { "const": "0.1" },
        "skill_id": { "$ref": "#/$defs/NonEmptyString" },
        "name": { "$ref": "#/$defs/NonEmptyString" },
        "purpose": { "$ref": "#/$defs/NonEmptyString" },
        "when_to_use": { "$ref": "#/$defs/NonEmptyStringArray" },
        "when_not_to_use": { "$ref": "#/$defs/NonEmptyStringArray" },
        "required_inputs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "method_steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/SkillMethodStep" } },
        "required_tools": { "$ref": "#/$defs/NonEmptyStringArray" },
        "optional_tools": { "$ref": "#/$defs/StringArray" },
        "agent_profile_hints": { "$ref": "#/$defs/NonEmptyStringArray" },
        "sub_agent_hints": { "$ref": "#/$defs/StringArray" },
        "quality_gates": { "$ref": "#/$defs/NonEmptyStringArray" },
        "risk_notes": { "$ref": "#/$defs/NonEmptyStringArray" },
        "expected_outputs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "observation_metrics": { "$ref": "#/$defs/NonEmptyStringArray" }
      }
    },
    "ToolGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "grant_id", "tool_id", "action_class", "allowed_actions", "scope", "workspace_boundary", "approval_required", "expires_after", "owning_agent_ref", "audit_level"],
      "properties": {
        "packet_type": { "const": "nexus.tool_grant" },
        "version": { "const": "0.1" },
        "grant_id": { "$ref": "#/$defs/NonEmptyString" },
        "tool_id": { "$ref": "#/$defs/NonEmptyString" },
        "action_class": { "$ref": "#/$defs/ToolActionClass" },
        "allowed_actions": { "$ref": "#/$defs/NonEmptyStringArray" },
        "scope": { "$ref": "#/$defs/NonEmptyString" },
        "workspace_boundary": { "$ref": "#/$defs/WorkspaceBoundary" },
        "approval_required": { "type": "boolean" },
        "approved_by": { "$ref": "#/$defs/NonEmptyString" },
        "expires_after": { "$ref": "#/$defs/NonEmptyString" },
        "source_skill_ref": { "$ref": "#/$defs/NonEmptyString" },
        "owning_agent_ref": { "$ref": "#/$defs/NonEmptyString" },
        "sub_agent_ref": { "$ref": "#/$defs/NonEmptyString" },
        "audit_level": { "$ref": "#/$defs/AuditLevel" }
      }
    },
    "AgentProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "agent_id", "profile", "role", "owned_scope", "responsibilities", "allowed_skill_refs", "default_tool_policy", "memory_access_policy", "context_access_policy", "evaluation_responsibility"],
      "properties": {
        "packet_type": { "const": "nexus.agent_profile" },
        "version": { "const": "0.1" },
        "agent_id": { "$ref": "#/$defs/NonEmptyString" },
        "profile": { "$ref": "#/$defs/NonEmptyString" },
        "role": { "$ref": "#/$defs/NonEmptyString" },
        "owned_scope": { "$ref": "#/$defs/NonEmptyString" },
        "responsibilities": { "$ref": "#/$defs/NonEmptyStringArray" },
        "allowed_skill_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "default_tool_policy": { "$ref": "#/$defs/NonEmptyString" },
        "memory_access_policy": { "$ref": "#/$defs/NonEmptyString" },
        "context_access_policy": { "$ref": "#/$defs/NonEmptyString" },
        "evaluation_responsibility": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "SubAgentDelegation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "sub_agent_id", "parent_agent_id", "scope", "allowed_tools", "active_context_ref", "expected_output", "handoff_format", "expires_after"],
      "properties": {
        "packet_type": { "const": "nexus.sub_agent_delegation" },
        "version": { "const": "0.1" },
        "sub_agent_id": { "$ref": "#/$defs/NonEmptyString" },
        "parent_agent_id": { "$ref": "#/$defs/NonEmptyString" },
        "scope": { "$ref": "#/$defs/NonEmptyString" },
        "allowed_tools": { "$ref": "#/$defs/NonEmptyStringArray" },
        "active_context_ref": { "$ref": "#/$defs/NonEmptyString" },
        "expected_output": { "$ref": "#/$defs/NonEmptyString" },
        "handoff_format": { "$ref": "#/$defs/NonEmptyString" },
        "expires_after": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "MemoryNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "note_id", "topic", "note_type", "summary", "source_refs", "confidence", "status", "created_at", "last_updated"],
      "if": { "properties": { "status": { "const": "stale" } } },
      "then": { "required": ["stale_reason"] },
      "properties": {
        "packet_type": { "const": "nexus.memory_note" },
        "version": { "const": "0.1" },
        "note_id": { "$ref": "#/$defs/NonEmptyString" },
        "topic": { "$ref": "#/$defs/NonEmptyString" },
        "note_type": { "$ref": "#/$defs/MemoryNoteType" },
        "summary": { "$ref": "#/$defs/NonEmptyString" },
        "source_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "confidence": { "$ref": "#/$defs/RuntimeConfidence" },
        "status": { "$ref": "#/$defs/MemoryNoteStatus" },
        "created_at": { "$ref": "#/$defs/NonEmptyString" },
        "last_updated": { "$ref": "#/$defs/NonEmptyString" },
        "stale_reason": { "$ref": "#/$defs/NonEmptyString" },
        "replaces": { "$ref": "#/$defs/StringArray" },
        "related_notes": { "$ref": "#/$defs/StringArray" }
      }
    },
    "ActiveContextBundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "context_id", "task_ref", "selected_note_refs", "current_constraints", "open_questions", "excluded_refs"],
      "properties": {
        "packet_type": { "const": "nexus.active_context_bundle" },
        "version": { "const": "0.1" },
        "context_id": { "$ref": "#/$defs/NonEmptyString" },
        "task_ref": { "$ref": "#/$defs/NonEmptyString" },
        "selected_note_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "current_constraints": { "$ref": "#/$defs/NonEmptyStringArray" },
        "open_questions": { "$ref": "#/$defs/StringArray" },
        "excluded_refs": { "type": "array", "items": { "$ref": "#/$defs/ExcludedRef" } }
      }
    },
    "EvaluationObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "observation_id", "run_ref", "subject_type", "subject_ref", "signal", "summary", "evidence_refs", "confidence"],
      "properties": {
        "packet_type": { "const": "nexus.evaluation_observation" },
        "version": { "const": "0.1" },
        "observation_id": { "$ref": "#/$defs/NonEmptyString" },
        "run_ref": { "$ref": "#/$defs/NonEmptyString" },
        "subject_type": { "$ref": "#/$defs/EvaluationSubjectType" },
        "subject_ref": { "$ref": "#/$defs/NonEmptyString" },
        "signal": { "$ref": "#/$defs/RuntimeSignal" },
        "summary": { "$ref": "#/$defs/NonEmptyString" },
        "evidence_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "confidence": { "$ref": "#/$defs/RuntimeConfidence" },
        "recommended_action": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "RuntimeLoopCycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["packet_type", "version", "cycle_id", "task_ref", "selected_skill_refs", "owning_agent_ref", "sub_agent_refs", "active_context_ref", "tool_grant_refs", "events", "artifact_refs", "evaluation_ref", "memory_note_update_refs", "status"],
      "properties": {
        "packet_type": { "const": "nexus.runtime_loop_cycle" },
        "version": { "const": "0.1" },
        "cycle_id": { "$ref": "#/$defs/NonEmptyString" },
        "task_ref": { "$ref": "#/$defs/NonEmptyString" },
        "selected_skill_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "owning_agent_ref": { "$ref": "#/$defs/NonEmptyString" },
        "sub_agent_refs": { "$ref": "#/$defs/StringArray" },
        "active_context_ref": { "$ref": "#/$defs/NonEmptyString" },
        "tool_grant_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "events": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/RuntimeEvent" } },
        "artifact_refs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/RuntimeArtifactRef" } },
        "evaluation_ref": { "$ref": "#/$defs/NonEmptyString" },
        "memory_note_update_refs": { "$ref": "#/$defs/NonEmptyStringArray" },
        "status": { "$ref": "#/$defs/RuntimeStatus" }
      }
    }
  }
}
