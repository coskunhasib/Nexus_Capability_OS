{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/trial-scenario.schema.json",
  "title": "Nexus Trial Scenario",
  "type": "object",
  "required": ["scenario_id", "version", "intent", "expected", "acceptance_criteria"],
  "properties": {
    "scenario_id": { "type": "string", "minLength": 1 },
    "version": { "const": "0.1" },
    "intent": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "expected": {
      "type": "object",
      "required": ["capability_pack", "macro_pipeline", "profiles", "micro_pipelines", "gates", "packets"],
      "properties": {
        "capability_pack": { "type": "string" },
        "macro_pipeline": { "type": "string" },
        "profiles": { "type": "array", "items": { "type": "string" } },
        "micro_pipelines": { "type": "array", "items": { "type": "string" } },
        "gates": { "type": "array", "items": { "type": "string" } },
        "packets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "acceptance_criteria": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "nexus_integration_notes": { "type": "array", "items": { "type": "string" } }
  }
}
